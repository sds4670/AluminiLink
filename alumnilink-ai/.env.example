# Database
POSTGRES_USER=alumnilink
POSTGRES_PASSWORD=alumnilink_secret
POSTGRES_DB=alumnilink_db
DATABASE_URL=postgresql+asyncpg://alumnilink:alumnilink_secret@postgres:5432/alumnilink_db

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
SECRET_KEY=change_this_to_a_random_secret_key_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Frontend
VITE_API_BASE_URL=http://localhost:8000

# ML (for future use)
OPENAI_API_KEY=
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Email (for future use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@alumnilink.ai

# App
APP_ENV=development
APP_NAME=AlumniLink AI
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
